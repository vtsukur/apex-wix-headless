---
// HeroScene.astro — generative hero: the racing line through a corner, drawn
// top-down as glowing line art on a 2D canvas. Zero assets, zero dependencies,
// nothing that could resemble a real marque. Under prefers-reduced-motion it
// renders one static frame; the animation pauses whenever the hero is
// offscreen, and DPR is capped so retina doesn't quadruple the fill cost.
---
<div class="hero-scene" aria-hidden="true">
  <canvas data-hero-canvas></canvas>
</div>

<script>
  function initHeroCanvas() {
    const canvas = document.querySelector("[data-hero-canvas]") as HTMLCanvasElement | null;
    if (!canvas || canvas.dataset.init) return;
    canvas.dataset.init = "1";
    const wrap = canvas.parentElement as HTMLElement;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    let w = 0;
    let h = 0;

    // ── Corner geometry — two joined quadratics: entry sweeps in from the
    //    bottom-left, the apex sits right-of-center (beside the headline),
    //    the exit fires off the top-right corner.
    const N = 220;
    const q = (a: number, b: number, c: number, t: number) =>
      (1 - t) * (1 - t) * a + 2 * (1 - t) * t * b + t * t * c;
    const A = [-0.08, 0.84]; // enters low-left, running nearly flat
    const C1 = [0.38, 0.9]; // dips through the entry phase
    const X = [0.64, 0.5]; // the apex
    const C2 = [0.88, 0.14]; // climbs hard after the apex
    const B = [0.96, -0.1]; // exits nearly vertical, top-right
    const pts: number[][] = [];
    for (let i = 0; i <= N; i++) {
      const u = i / N;
      const s = u < 0.5 ? u * 2 : u * 2 - 1;
      pts.push(
        u < 0.5
          ? [q(A[0], C1[0], X[0], s), q(A[1], C1[1], X[1], s)]
          : [q(X[0], C2[0], B[0], s), q(X[1], C2[1], B[1], s)],
      );
    }
    const APEX_U = 0.5;
    const apexIdx = Math.round(APEX_U * N);

    // ── Anamorphic streaks — slow horizontal light smears.
    const rand = (min: number, max: number) => min + Math.random() * (max - min);
    const streaks = Array.from({ length: 9 }, () => ({
      y: Math.random(),
      len: rand(0.14, 0.42),
      sp: rand(0.6, 2.2),
      off: Math.random(),
      a: rand(0.015, 0.045),
      lw: rand(0.75, 1.5),
    }));

    const px = (p: number[]) => [p[0] * w, p[1] * h];
    const normalAt = (i: number) => {
      const a = pts[Math.max(0, i - 2)];
      const b = pts[Math.min(N, i + 2)];
      const dx = (b[0] - a[0]) * w;
      const dy = (b[1] - a[1]) * h;
      const l = Math.hypot(dx, dy) || 1;
      return [-dy / l, dx / l];
    };

    function strokeSegment(from: number, to: number, style: string, width: number, blur = 0, blurColor = "") {
      const i0 = Math.max(0, Math.round(from * N));
      const i1 = Math.min(N, Math.round(to * N));
      if (i1 - i0 < 1) return;
      ctx!.beginPath();
      const [x0, y0] = px(pts[i0]);
      ctx!.moveTo(x0, y0);
      for (let i = i0 + 1; i <= i1; i++) {
        const [x, y] = px(pts[i]);
        ctx!.lineTo(x, y);
      }
      ctx!.strokeStyle = style;
      ctx!.lineWidth = width;
      ctx!.lineCap = "round";
      ctx!.lineJoin = "round";
      ctx!.shadowBlur = blur;
      ctx!.shadowColor = blurColor;
      ctx!.stroke();
      ctx!.shadowBlur = 0;
    }

    function draw(t: number) {
      ctx!.clearRect(0, 0, w, h);

      // Streaks.
      for (const s of streaks) {
        const span = w * (1 + s.len);
        const head = ((s.off + (t * 0.00003 * s.sp)) % 1) * span;
        const y = s.y * h;
        const len = s.len * w;
        const grad = ctx!.createLinearGradient(head - len, y, head, y);
        grad.addColorStop(0, "rgba(242,240,235,0)");
        grad.addColorStop(0.7, `rgba(242,240,235,${s.a})`);
        grad.addColorStop(1, "rgba(242,240,235,0)");
        ctx!.beginPath();
        ctx!.moveTo(head - len, y);
        ctx!.lineTo(head, y);
        ctx!.strokeStyle = grad;
        ctx!.lineWidth = s.lw;
        ctx!.stroke();
      }

      // Track edges — offset polylines either side of the line.
      const EDGE = Math.max(34, h * 0.055);
      for (const side of [-1, 1]) {
        ctx!.beginPath();
        for (let i = 0; i <= N; i++) {
          const [x, y] = px(pts[i]);
          const [nx, ny] = normalAt(i);
          const ex = x + nx * EDGE * side;
          const ey = y + ny * EDGE * side;
          if (i === 0) ctx!.moveTo(ex, ey);
          else ctx!.lineTo(ex, ey);
        }
        ctx!.strokeStyle = "rgba(242,240,235,0.055)";
        ctx!.lineWidth = 1;
        ctx!.stroke();
      }

      // Kerb ticks around the apex — alternating red/bone, outside edge.
      for (let k = -16; k <= 16; k += 4) {
        const i = Math.max(2, Math.min(N - 2, apexIdx + k));
        const [x, y] = px(pts[i]);
        const [nx, ny] = normalAt(i);
        ctx!.beginPath();
        ctx!.moveTo(x + nx * (EDGE + 4), y + ny * (EDGE + 4));
        ctx!.lineTo(x + nx * (EDGE + 14), y + ny * (EDGE + 14));
        ctx!.strokeStyle = (k / 4) % 2 === 0 ? "rgba(225,18,31,0.16)" : "rgba(242,240,235,0.12)";
        ctx!.lineWidth = 3;
        ctx!.stroke();
      }

      // The racing line — full path low, bright pulse sweeping through.
      strokeSegment(0, 1, "rgba(225,18,31,0.3)", 1.5, 14, "rgba(225,18,31,0.5)");
      const p = (t * 0.000155) % 1;
      const tail = p - 0.085;
      const bright = "rgba(255,92,92,0.92)";
      const glow = "rgba(225,18,31,0.9)";
      if (tail >= 0) {
        strokeSegment(tail, p, bright, 2.5, 22, glow);
      } else {
        strokeSegment(0, p, bright, 2.5, 22, glow);
        strokeSegment(1 + tail, 1, bright, 2.5, 22, glow);
      }

      // Apex marker + pulse ring when the head passes.
      const [ax, ay] = px(pts[apexIdx]);
      ctx!.beginPath();
      ctx!.arc(ax, ay, 2.5, 0, Math.PI * 2);
      ctx!.fillStyle = "rgba(225,18,31,0.85)";
      ctx!.fill();
      if (p > APEX_U && p < APEX_U + 0.12) {
        const k = (p - APEX_U) / 0.12;
        ctx!.beginPath();
        ctx!.arc(ax, ay, 6 + k * 64, 0, Math.PI * 2);
        ctx!.strokeStyle = `rgba(225,18,31,${(1 - k) * 0.45})`;
        ctx!.lineWidth = 1;
        ctx!.stroke();
      }

      // Vignette — pull the edges down for depth.
      const vg = ctx!.createRadialGradient(w * 0.6, h * 0.45, Math.min(w, h) * 0.35, w * 0.6, h * 0.45, Math.max(w, h) * 0.75);
      vg.addColorStop(0, "rgba(10,10,11,0)");
      vg.addColorStop(1, "rgba(10,10,11,0.5)");
      ctx!.fillStyle = vg;
      ctx!.fillRect(0, 0, w, h);
    }

    const resize = () => {
      const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
      w = wrap.clientWidth;
      h = wrap.clientHeight;
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      if (reduced) draw(3550); // static frame: pulse held just past the apex
    };
    new ResizeObserver(resize).observe(wrap);
    resize();

    if (reduced) return;

    let running = false;
    let rafId = 0;
    const loop = (t: number) => {
      draw(t);
      rafId = requestAnimationFrame(loop);
    };
    const io = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting && !running) {
        running = true;
        rafId = requestAnimationFrame(loop);
      } else if (!entry.isIntersecting && running) {
        running = false;
        cancelAnimationFrame(rafId);
      }
    });
    io.observe(canvas);
  }

  initHeroCanvas();
  document.addEventListener("astro:page-load", initHeroCanvas);
</script>
