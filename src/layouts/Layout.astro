---
import '../styles/global.css';
import '../styles/components-bookings.css';
import { ClientRouter } from 'astro:transitions';
import BootScreen from '../components/BootScreen.astro';
import CtaFluid from '../components/CtaFluid.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  hasSeoTags?: boolean;
}
const { title, description, hasSeoTags = false } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Entry-curtain gate — must run before first paint. Shows the boot
      // overlay only on the first hard load of a session and never under
      // reduced motion; the 5s watchdog guarantees the page can't stay
      // covered if anything downstream fails.
      try {
        if (
          !sessionStorage.getItem("apex:booted") &&
          !matchMedia("(prefers-reduced-motion: reduce)").matches
        ) {
          document.documentElement.classList.add("booting");
          setTimeout(function () {
            document.documentElement.classList.remove("booting");
          }, 13000);
        }
      } catch (e) {}
    </script>
    <!-- The brand tick — the red corner-apex mark (heavy top-left round).
         Transparent margin keeps it tick-sized in the tab, not a full tile. -->
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Cpath d='M13 3 A10 10 0 0 0 3 13 L13 13 Z' fill='%23E1121F'/%3E%3C/svg%3E" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400..600;1,14..32,400..600&family=Oswald:wght@300..700&display=swap" />
    {!hasSeoTags && (
      <>
        <title>{title ? `${title} · APEX` : "APEX"}</title>
        {description && <meta name="description" content={description} />}
      </>
    )}
    <slot name="head" />
    <ClientRouter />
  </head>
  <body>
    <BootScreen />
    <CtaFluid />
    <div class="film-grain" aria-hidden="true"></div>
    <div class="nav-progress" data-nav-progress aria-hidden="true"></div>
    <Navigation />
    <main><slot /></main>
    <Footer />
    <script>
      // Persisted rail aria-current sync + top loading bar + rail-anchored
      // scroll across listing-to-listing navigation. Stores pack relies on
      // all three; do not split into separate scripts.
      function syncCategoryRail() {
        const path = window.location.pathname;
        const activeSlug = path.startsWith("/category/")
          ? path.slice("/category/".length).replace(/\/$/, "")
          : path === "/products" || path === "/products/"
            ? ""
            : null;
        if (activeSlug === null) return;
        const pills = document.querySelectorAll<HTMLAnchorElement>(
          "[data-category-rail] .category-pill",
        );
        for (const pill of pills) {
          const slug = pill.dataset.categorySlug ?? "";
          if (slug === activeSlug) pill.setAttribute("aria-current", "page");
          else pill.removeAttribute("aria-current");
        }
      }
      // Eager click feedback — flip aria-current before the network call.
      document.addEventListener("click", (event) => {
        const target = event.target as HTMLElement | null;
        const pill = target?.closest<HTMLAnchorElement>(
          "[data-category-rail] .category-pill",
        );
        if (!pill) return;
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
        const pills = document.querySelectorAll<HTMLAnchorElement>(
          "[data-category-rail] .category-pill",
        );
        for (const p of pills) p.removeAttribute("aria-current");
        pill.setAttribute("aria-current", "page");
      }, true);
      const progress = document.querySelector<HTMLElement>("[data-nav-progress]");
      function startProgress() {
        if (!progress) return;
        progress.dataset.state = "loading";
        document.body.dataset.navigating = "true";
      }
      function endProgress() {
        if (!progress) return;
        progress.dataset.state = "done";
        delete document.body.dataset.navigating;
        window.setTimeout(() => {
          if (progress.dataset.state === "done") delete progress.dataset.state;
        }, 320);
      }
      // Anchor the persisted rail across listing-to-listing navigation. The
      // page-header above the rail differs between /products and /category/[slug]
      // (breadcrumbs, lede, optional image), so naive scroll preservation reads
      // as a jump. Capture rail.getBoundingClientRect().top before the swap and
      // re-equalize after.
      const isListing = (p: string) =>
        p === "/products" || p === "/products/" || p.startsWith("/category/");
      let railAnchorTop: number | null = null;
      document.addEventListener("astro:before-preparation", (event: any) => {
        const from = window.location.pathname;
        const to = event?.to?.pathname ?? from;
        const rail = document.querySelector<HTMLElement>("[data-category-rail]");
        railAnchorTop =
          rail && isListing(from) && isListing(to)
            ? rail.getBoundingClientRect().top
            : null;
        startProgress();
      });
      document.addEventListener("astro:after-swap", () => {
        syncCategoryRail();
        if (railAnchorTop !== null) {
          const rail = document.querySelector<HTMLElement>("[data-category-rail]");
          if (rail) {
            const delta = rail.getBoundingClientRect().top - railAnchorTop;
            if (Math.abs(delta) > 0.5) {
              window.scrollBy({ top: delta, left: 0, behavior: "instant" as ScrollBehavior });
            }
          }
        }
        railAnchorTop = null;
        endProgress();
      });
      document.addEventListener("astro:page-load", endProgress);
      syncCategoryRail();
    </script>
    <script>
      // Cinematic motion layer — Lenis smooth scroll + reveal-on-scroll.
      // Respects prefers-reduced-motion (no smoothing, reveals shown instantly)
      // and replays reveal setup after every ClientRouter swap.
      import Lenis from "lenis";

      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // Past-hero gate — mobile CSS collapses the header to the plain bar
      // (no curve pocket, no lap) once the page is meaningfully scrolled.
      const heroGate = () => {
        document.documentElement.classList.toggle(
          "past-hero",
          window.scrollY > window.innerHeight * 0.5,
        );
      };
      window.addEventListener("scroll", heroGate, { passive: true });
      heroGate();

      // Scroll-driven effects — hero parallax-exit + pinned fleet progress.
      // Re-scanned after every ClientRouter swap; a no-op on pages without the
      // hooks. Under reduced motion nothing runs (CSS shows the static layout).
      let heroEl: HTMLElement | null = null;
      let heroScene: HTMLElement | null = null;
      let pinStages: HTMLElement[] = [];
      function scanScrollFx() {
        heroEl = document.querySelector("[data-hero-parallax]");
        heroScene = document.querySelector(".hero-scene");
        pinStages = Array.from(document.querySelectorAll("[data-pin-stage]"));
        // Snap each scroller dot onto the browser's own arc parametrization —
        // getPointAtLength matches the dash-fill math exactly, so the fill
        // touches a circle at precisely its data-pin-dot fraction (the SSR
        // inline positions are close-enough estimates until this runs).
        // Layout offsets ignore transforms, so this stays idempotent.
        const topWithin = (el: Element | null, root: Element): number => {
          let y = 0;
          while (el && el !== root) {
            y += (el as HTMLElement).offsetTop;
            el = (el as HTMLElement).offsetParent;
          }
          return y;
        };
        for (const stage of pinStages) {
          const path = stage.querySelector<SVGPathElement>(".pin-curve-base");
          const box = path?.ownerSVGElement?.viewBox?.baseVal;
          if (!path || !box) continue;
          const total = path.getTotalLength();
          stage.querySelectorAll<HTMLElement>("[data-pin-dot]").forEach((dot) => {
            const f = parseFloat(dot.dataset.pinDot ?? "0");
            const pt = path.getPointAtLength(f * total);
            dot.style.left = `${(pt.x / box.width) * 100}%`;
            dot.style.top = `${pt.y}px`;
          });
          // Deck slide-in span — distance from the card's right edge back to
          // the screen's left edge (layout offsets, so transform-immune).
          // applyScrollFx reads it hot every frame; recomputed on resize.
          const carsBox = stage.querySelector<HTMLElement>(".pin-cars");
          if (carsBox) {
            let px = 0;
            let node: Element | null = carsBox;
            while (node) {
              px += (node as HTMLElement).offsetLeft;
              node = (node as HTMLElement).offsetParent;
            }
            carsBox.dataset.slideSpan = String(px + carsBox.offsetWidth);
          }
          // Center the scroller vertically in the band between the pinned
          // viewport's top (where the hero ends) and the car image's top.
          // Centered by its visible ink (curve + circles + numerals), not
          // its layout box — the numerals hang below the box's bottom edge.
          // Desktop only: on mobile the scroller stacks under the title.
          const vp = stage.querySelector<HTMLElement>(".pin-viewport");
          const carsEl = stage.querySelector<HTMLElement>(".pin-cars");
          const prog = stage.querySelector<HTMLElement>(".pin-progress");
          if (!vp || !carsEl || !prog || !prog.offsetParent) continue;
          if (window.matchMedia("(min-width: 768px)").matches) {
            // Child rects relative to the box's own rect share its transform,
            // so this measure stays idempotent across re-runs.
            const pr = prog.getBoundingClientRect();
            let inkTop = Infinity;
            let inkBottom = -Infinity;
            prog.querySelectorAll(".pin-curve-base, .pin-dot, .pin-dot-num").forEach((el) => {
              const r = el.getBoundingClientRect();
              inkTop = Math.min(inkTop, r.top);
              inkBottom = Math.max(inkBottom, r.bottom);
            });
            if (inkTop > inkBottom) {
              inkTop = pr.top;
              inkBottom = pr.bottom;
            }
            const inkCenter = (inkTop + inkBottom) / 2 - pr.top;
            // Dead-center reads slightly high next to the title — bias down.
            const target = topWithin(carsEl, vp) / 2 - inkCenter + 28;
            const delta = Math.round(target - topWithin(prog, vp));
            prog.style.transform = delta ? `translateY(${delta}px)` : "";
          } else {
            prog.style.transform = "";
          }
        }
      }
      function applyScrollFx() {
        const y = window.scrollY;
        const vh = window.innerHeight;
        if (heroEl) {
          const k = Math.min(y / (vh * 0.9), 1);
          heroEl.style.transform = `translateY(${y * 0.28}px)`;
          heroEl.style.opacity = String(1 - k * 0.9);
          if (heroScene) heroScene.style.transform = `translateY(${y * 0.14}px)`;
        }
        for (const stage of pinStages) {
          const rect = stage.getBoundingClientRect();
          const total = rect.height - vh;
          const p = total > 0 ? Math.min(Math.max(-rect.top / total, 0), 1) : 0;
          // Roll the deck in from the screen's left edge as the stage scrolls
          // up into place — eased, settling just before the pin engages, and
          // rolling back out on the way up (scroll-linked both ways).
          const carsWrap = stage.querySelector<HTMLElement>(".pin-cars");
          if (carsWrap?.dataset.slideSpan) {
            const e = Math.min(Math.max(1 - rect.top / (vh * 0.85), 0), 1);
            const k = 1 - Math.pow(1 - e, 3);
            carsWrap.style.transform =
              k < 1
                ? `translateX(${(-Number(carsWrap.dataset.slideSpan) * (1 - k)).toFixed(1)}px)`
                : "";
          }
          const cars = stage.querySelectorAll<HTMLElement>(".pin-car");
          const idx = Math.min(cars.length - 1, Math.floor(p * cars.length));
          cars.forEach((car, i) => {
            car.classList.toggle("is-active", i === idx);
            car.dataset.stack = String(i - idx); // deck position vs the focus card
          });
          // Fleet films — the focus car's video rolls ~0.5s after its card
          // settles, and fades in only once playback actually starts (the
          // still underneath holds the frame until then). Leaving the beat
          // or scrolling the stage away pauses everything.
          const onstage = rect.bottom > 0 && rect.top < vh;
          const beat = onstage ? String(idx) : "off";
          if (stage.dataset.liveBeat !== beat) {
            stage.dataset.liveBeat = beat;
            cars.forEach((car, i) => {
              const vid = car.querySelector<HTMLVideoElement>(".pin-car-media video");
              if (!vid) return;
              clearTimeout(Number(vid.dataset.cue || 0));
              if (onstage && i === idx) {
                vid.dataset.cue = String(
                  window.setTimeout(() => {
                    vid
                      .play()
                      .then(() => car.classList.add("video-live"))
                      .catch(() => {}); // autoplay blocked / not transcoded yet — still stays
                  }, 500),
                );
              } else {
                car.classList.remove("video-live");
                vid.pause();
              }
            });
          }
          const count = stage.querySelector<HTMLElement>("[data-pin-count]");
          if (count) count.textContent = String(idx + 1).padStart(2, "0");
          const dots = stage.querySelectorAll<HTMLElement>("[data-pin-dot]");
          dots.forEach((dot, i) => dot.classList.toggle("on", i <= idx));
          stage.querySelector(".pin-nav-prev")?.toggleAttribute("disabled", idx === 0);
          stage.querySelector(".pin-nav-next")?.toggleAttribute("disabled", idx === cars.length - 1);
          // Plateau map through the circle stops (arc fractions on
          // data-pin-dot): while car k is on stage the fill rests centered in
          // circle k; across each beat boundary it sweeps smoothly to the
          // next circle (scroll-driven and continuous — the sweep spans the
          // last/first EDGE of the adjacent beats, meeting halfway exactly at
          // the boundary).
          const bar = stage.querySelector<HTMLElement>("[data-pin-bar]");
          if (bar && dots.length > 0) {
            const stops = Array.from(dots).map((d) => parseFloat(d.dataset.pinDot ?? "0"));
            const n = stops.length;
            const EDGE = 0.18;
            const seg = Math.min(n - 1e-6, p * n);
            const k = Math.floor(seg);
            const t = seg - k;
            let fill = stops[k];
            if (t < EDGE && k > 0) {
              fill = stops[k - 1] + (stops[k] - stops[k - 1]) * (0.5 + (0.5 * t) / EDGE);
            } else if (t > 1 - EDGE && k < n - 1) {
              fill = stops[k] + (stops[k + 1] - stops[k]) * ((0.5 * (t - (1 - EDGE))) / EDGE);
            } else if (t > 1 - EDGE) {
              // Final beat — complete the short run-out by section end.
              fill = stops[k] + (1 - stops[k]) * ((t - (1 - EDGE)) / EDGE);
            }
            bar.style.setProperty("--p", String(fill));
          }
        }
      }

      let lenis: Lenis | null = null;
      if (!reduced) {
        lenis = new Lenis({ lerp: 0.11 });
        scanScrollFx();
        // Geometry-dependent placement (dots, scroller centering) tracks
        // viewport and web-font layout shifts.
        window.addEventListener("resize", scanScrollFx);
        document.fonts?.ready.then(scanScrollFx);
        const raf = (time: number) => {
          lenis?.raf(time);
          applyScrollFx();
          requestAnimationFrame(raf);
        };
        requestAnimationFrame(raf);
      }

      // Scroller circles and card chevrons share one behavior: scroll the
      // pinned stage to the center of car i's beat (fill centered in its
      // circle). Chevrons step relative to the beat under the current scroll.
      function scrollToBeat(stage: HTMLElement, i: number, count: number) {
        const total = stage.offsetHeight - window.innerHeight;
        const top = stage.getBoundingClientRect().top + window.scrollY;
        const target = top + ((Math.max(0, Math.min(count - 1, i)) + 0.5) / count) * total;
        if (lenis) lenis.scrollTo(target, { duration: 1.1 });
        else window.scrollTo({ top: target, behavior: "smooth" });
      }
      document.addEventListener("click", (event) => {
        const el = event.target as HTMLElement | null;
        const dot = el?.closest?.<HTMLElement>("[data-pin-dot]");
        if (dot) {
          const stage = dot.closest<HTMLElement>("[data-pin-stage]");
          if (!stage) return;
          const dots = Array.from(stage.querySelectorAll("[data-pin-dot]"));
          scrollToBeat(stage, dots.indexOf(dot), dots.length);
          return;
        }
        const nav = el?.closest?.<HTMLElement>("[data-pin-nav]");
        if (nav) {
          const stage = nav.closest<HTMLElement>("[data-pin-stage]");
          if (!stage) return;
          const n = stage.querySelectorAll(".pin-car").length;
          const rect = stage.getBoundingClientRect();
          const total = rect.height - window.innerHeight;
          const p = total > 0 ? Math.min(Math.max(-rect.top / total, 0), 1) : 0;
          const idx = Math.min(n - 1, Math.floor(p * n));
          scrollToBeat(stage, idx + Number(nav.dataset.pinNav || 0), n);
        }
      });

      function setupReveals() {
        const els = document.querySelectorAll<HTMLElement>("[data-reveal]:not(.in)");
        if (reduced) {
          els.forEach((el) => el.classList.add("in"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("in");
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" },
        );
        els.forEach((el) => io.observe(el));
      }

      // Roll-through elements (data-roll) enter AND exit with the scroll —
      // the class toggles both ways, so the roll replays on every pass.
      function setupRolls() {
        const els = document.querySelectorAll<HTMLElement>("[data-roll]:not([data-roll-live])");
        if (!els.length) return;
        els.forEach((el) => el.setAttribute("data-roll-live", "1"));
        if (reduced) {
          els.forEach((el) => el.classList.add("in"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              entry.target.classList.toggle("in", entry.isIntersecting);
            }
          },
          { threshold: 0.1, rootMargin: "0px 0px -4% 0px" },
        );
        els.forEach((el) => io.observe(el));
      }

      // Hold the first reveal pass while the boot curtain is up so the hero
      // rises as the curtain clears, not hidden behind it.
      if (document.documentElement.classList.contains("booting")) {
        document.addEventListener("apex:boot-done", () => setupReveals(), { once: true });
      } else {
        setupReveals();
      }
      setupRolls();
      document.addEventListener("astro:page-load", () => {
        setupReveals();
        setupRolls();
        scanScrollFx();
        heroGate();
      });
      document.addEventListener("astro:after-swap", () => {
        lenis?.scrollTo(0, { immediate: true });
      });
    </script>
  </body>
</html>
