---
// src/pages/404.astro — the run-off area. Rendered by Astro for every
// unmatched route (status 404 comes with it); the explicit status below
// covers direct visits to /404 too.
import Layout from "../layouts/Layout.astro";

Astro.response.status = 404;

// Echo the missed line back to the driver — truncated so a hostile-length
// URL can't distort the layout (Astro escapes the interpolation).
const path = Astro.url.pathname;
const shownPath = path.length > 48 ? `${path.slice(0, 48)}…` : path;
---

<Layout title="Off track" noindex>
  <section class="max-w-3xl mx-auto px-6 pt-8 pb-24 flex flex-col items-center text-center gap-6">
    <p class="eyebrow" data-reveal>Run-off area</p>

    <!-- The scene: a ghost 404 board behind the racing line. The line sweeps
         the corner; one dashed trail misses it and dies in the gravel, where
         the marker pulses. Draw-in keys off the reveal class so it plays
         after the boot curtain, never under it. -->
    <div class="offtrack-scene w-full" data-reveal aria-hidden="true">
      <span class="offtrack-ghost">404</span>
      <svg viewBox="0 0 720 300" fill="none" preserveAspectRatio="xMidYMid meet">
        <!-- kerb ticks riding the outside of the apex -->
        <g class="offtrack-kerbs" stroke-width="3">
          <line x1="361" y1="198" x2="365" y2="207" class="kerb-a" />
          <line x1="399" y1="179" x2="404" y2="187" class="kerb-b" />
          <line x1="435" y1="157" x2="440" y2="165" class="kerb-a" />
          <line x1="461" y1="139" x2="466" y2="147" class="kerb-b" />
          <line x1="488" y1="121" x2="493" y2="130" class="kerb-a" />
        </g>

        <!-- the racing line — glow underlay + line share one draw animation -->
        <path
          d="M -20 250 Q 260 265 430 150 Q 560 60 720 -20"
          pathLength="100"
          class="offtrack-line offtrack-line-glow"
        />
        <path
          d="M -20 250 Q 260 265 430 150 Q 560 60 720 -20"
          pathLength="100"
          class="offtrack-line offtrack-line-core"
        />

        <!-- the missed corner: brake-lock skid, then the dashed run into the gravel -->
        <g class="offtrack-skid" stroke-width="2.5">
          <line x1="228" y1="232" x2="285" y2="217" />
          <line x1="234" y1="241" x2="291" y2="226" />
        </g>
        <path
          d="M 255 227 L 623 132"
          pathLength="100"
          class="offtrack-trail"
        />

        <!-- the gravel trap -->
        <g class="offtrack-gravel">
          <circle cx="500" cy="170" r="1.2" /><circle cx="516" cy="190" r="1.4" />
          <circle cx="523" cy="132" r="1.1" /><circle cx="536" cy="178" r="1.2" />
          <circle cx="543" cy="151" r="1.4" /><circle cx="552" cy="168" r="1.6" />
          <circle cx="563" cy="142" r="1.2" /><circle cx="569" cy="199" r="1.3" />
          <circle cx="571" cy="181" r="2" /><circle cx="578" cy="120" r="1.3" />
          <circle cx="586" cy="158" r="1.7" /><circle cx="592" cy="187" r="1.4" />
          <circle cx="598" cy="131" r="1.2" /><circle cx="604" cy="170" r="2.1" />
          <circle cx="607" cy="203" r="1.5" /><circle cx="611" cy="147" r="1.3" />
          <circle cx="617" cy="189" r="1.6" /><circle cx="622" cy="160" r="1.2" />
          <circle cx="629" cy="120" r="1.4" /><circle cx="633" cy="176" r="1.8" />
          <circle cx="640" cy="143" r="1.2" /><circle cx="645" cy="199" r="1.4" />
          <circle cx="646" cy="163" r="1.5" /><circle cx="651" cy="127" r="1.3" />
          <circle cx="657" cy="186" r="1.9" /><circle cx="663" cy="151" r="1.3" />
          <circle cx="669" cy="171" r="1.5" /><circle cx="674" cy="136" r="1.2" />
          <circle cx="681" cy="158" r="1.7" /><circle cx="687" cy="178" r="1.3" />
          <circle cx="692" cy="144" r="1.4" /><circle cx="699" cy="165" r="1.8" />
        </g>

        <!-- where you ended up -->
        <g class="offtrack-marker">
          <circle cx="623" cy="132" r="8" class="offtrack-ring" />
          <circle cx="623" cy="132" r="4" class="offtrack-dot" />
          <text x="623" y="104" text-anchor="middle" class="offtrack-label">You are here</text>
        </g>
      </svg>
    </div>

    <h1 class="display-lg" data-reveal>
      You've gone off track<span class="accent-dot" aria-hidden="true"></span>
    </h1>

    <div class="flex flex-col items-center gap-3" data-reveal>
      <p class="text-lg text-mute leading-relaxed max-w-prose">
        There's nothing down this line but gravel. Rejoin where the tarmac
        starts.
      </p>
      <p class="text-sm text-mute">
        No timing data for <span class="offtrack-path">{shownPath}</span>
      </p>
    </div>

    <div class="flex flex-col sm:flex-row items-center gap-4 mt-2" data-reveal>
      <a href="/" class="btn-primary">Back to the grid</a>
      <a href="/services" class="btn-secondary">View sessions</a>
    </div>
  </section>
</Layout>

<style>
  /* The ghost 404 — a distance board behind the line, outlined so it sits
     in the dark without competing with the drawn geometry. */
  .offtrack-scene {
    position: relative;
  }
  .offtrack-ghost {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(6rem, 20vw, 12rem);
    line-height: 1;
    letter-spacing: 0.04em;
    color: rgba(242, 240, 235, 0.04);
    -webkit-text-stroke: 1px var(--color-rule);
    user-select: none;
  }
  .offtrack-scene svg {
    position: relative;
    display: block;
    width: 100%;
    height: auto;
  }

  .offtrack-line-glow {
    stroke: rgba(225, 18, 31, 0.35);
    stroke-width: 8;
    stroke-linecap: round;
  }
  .offtrack-line-core {
    stroke: var(--color-accent);
    stroke-width: 2;
    stroke-linecap: round;
  }
  .kerb-a { stroke: rgba(225, 18, 31, 0.4); }
  .kerb-b { stroke: rgba(242, 240, 235, 0.25); }
  .offtrack-skid line {
    stroke: rgba(242, 240, 235, 0.14);
    stroke-linecap: round;
  }
  .offtrack-trail {
    stroke: var(--color-ink-soft);
    stroke-width: 1.5;
    stroke-dasharray: 1.2 2.6;
    opacity: 0.45;
  }
  .offtrack-gravel circle {
    fill: var(--color-mute);
  }
  .offtrack-gravel {
    opacity: 0.4;
  }
  .offtrack-dot {
    fill: var(--color-accent);
  }
  .offtrack-ring {
    stroke: var(--color-accent);
    stroke-width: 1;
    fill: none;
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
  }
  .offtrack-label {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    fill: var(--color-ink-soft);
  }
  .offtrack-path {
    font-family: var(--font-display);
    letter-spacing: 0.08em;
    color: var(--color-ink-soft);
    overflow-wrap: anywhere;
  }

  /* Choreography — keyed to the reveal's .in (post-curtain): the line draws
     the corner, the trail and gravel fade up where it was missed, the marker
     lands last and its ring keeps pulsing. Reduced motion shows it all
     settled, no animation. */
  @media (prefers-reduced-motion: no-preference) {
    .offtrack-line {
      stroke-dasharray: 100;
      stroke-dashoffset: 100;
    }
    .offtrack-scene.in .offtrack-line {
      animation: offtrack-draw 1.3s cubic-bezier(0.6, 0, 0.2, 1) 0.2s forwards;
    }
    .offtrack-trail,
    .offtrack-skid,
    .offtrack-gravel,
    .offtrack-dot,
    .offtrack-label {
      opacity: 0;
    }
    .offtrack-scene.in .offtrack-skid { animation: offtrack-in 0.6s ease 0.9s forwards; }
    .offtrack-scene.in .offtrack-trail { animation: offtrack-in 0.7s ease 1.05s forwards; }
    .offtrack-scene.in .offtrack-gravel { animation: offtrack-in 0.8s ease 1.25s forwards; }
    .offtrack-scene.in .offtrack-dot,
    .offtrack-scene.in .offtrack-label { animation: offtrack-in 0.5s ease 1.5s forwards; }
    .offtrack-scene.in .offtrack-ring {
      animation: offtrack-pulse 2.6s ease-out 1.8s infinite;
    }
  }
  @keyframes offtrack-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes offtrack-in {
    to { opacity: var(--to, 1); }
  }
  .offtrack-trail { --to: 0.45; }
  .offtrack-gravel { --to: 0.4; }
  @keyframes offtrack-pulse {
    0% { transform: scale(0.4); opacity: 0.6; }
    70% { transform: scale(2.6); opacity: 0; }
    100% { transform: scale(2.6); opacity: 0; }
  }
</style>
