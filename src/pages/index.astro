---
// Home — five full-viewport scenes (Pagani pacing · Rimac scale · Aston
// refinement · Exo Ape motion). The hero carries the TH-12 lap film (streamed
// from Wix Media, never committed to the repo) with a parallax exit; the
// fleet is a pinned scroll sequence (one car per scroll beat). Programmes are
// queried live from Wix Bookings (non-fatal — degrades to a CTA on failure).
import Layout from '../layouts/Layout.astro';
import { services } from "@wix/bookings";
import { auth } from "@wix/essentials";

const BOOKING_APP_ID = "13d21c63-b5ec-5912-8397-c3a5ddb27a97";

const result = await auth
  .elevate(services.queryServices)()
  .eq("appId", BOOKING_APP_ID)
  .limit(8)
  .find()
  .catch((err: any) => { console.error("[home] programmes query failed:", err); return null; });

const programmes: any[] = (result?.items ?? []).filter((s: any) => !s.hidden);

const getSlug = (s: any): string => s.mainSlug?.name ?? s.supportedSlugs?.[0]?.name ?? s._id;
const getDuration = (s: any): number => s.schedule?.availabilityConstraints?.sessionDurations?.[0] ?? 60;
const formatPrice = (s: any): string | undefined => {
  const p = s.payment;
  if (!p || p.rateType === "NO_FEE") return undefined;
  if (p.rateType === "FIXED" && p.fixed?.price) {
    const { value, currency } = p.fixed.price;
    if (!value) return undefined;
    return new Intl.NumberFormat("en-IE", {
      style: "currency",
      currency: currency ?? "EUR",
      maximumFractionDigits: 0,
    }).format(Number(value));
  }
  return undefined;
};

// The fleet — fictional in-house designations only. Imagery is AI-generated
// original design (badge-free, no real marque), served from Wix Media.
const fleet = [
  {
    designation: "TH-12",
    role: "The circuit weapon. Mid-engined, downforce-led, honest at the limit.",
    image: "https://static.wixstatic.com/media/67964a_688bd941058043ffad139b51410e5983~mv2.png/v1/fill/w_1376,h_768,q_85/th-12.jpg",
    alt: "TH-12 hypercar cornering at the apex of a dark circuit at dusk, brake discs glowing",
    specs: [
      { value: "830", unit: "PS", label: "Power" },
      { value: "2.9", unit: "s", label: "0–100 km/h" },
      { value: "340", unit: "km/h", label: "Top speed" },
    ],
  },
  {
    designation: "RS-Launch",
    role: "The launch specialist. All-wheel drive, telemetry on every run.",
    image: "https://static.wixstatic.com/media/67964a_75f55bba9ff64d86bfc4d983c9bb8b7e~mv2.png/v1/fill/w_1376,h_768,q_85/rs-launch.jpg",
    alt: "RS-Launch coupe launching from the start line at night, tire smoke trailing",
    specs: [
      { value: "740", unit: "PS", label: "Power" },
      { value: "2.6", unit: "s", label: "0–100 km/h" },
      { value: "305", unit: "km/h", label: "Top speed" },
    ],
  },
  {
    designation: "Apex GT",
    role: "The grand tourer. Long-legged, unhurried, built for the high passes.",
    image: "https://static.wixstatic.com/media/67964a_98ec9d42fd54409fac49b479d2b0d2d0~mv2.png/v1/fill/w_1376,h_768,q_85/apex-gt.jpg",
    alt: "Apex GT sweeping through an alpine hairpin at blue hour, tail lights tracing the road",
    specs: [
      { value: "700", unit: "PS", label: "Power" },
      { value: "3.4", unit: "s", label: "0–100 km/h" },
      { value: "320", unit: "km/h", label: "Top speed" },
    ],
  },
];
---
<Layout>
  <!-- Scene 1 — hero: TH-12 lap film (Wix Media) + parallax exit. The video is
       NOT in the repo — it lives in the site's Wix Media and streams from the
       wixstatic CDN. The boot curtain waits for it (BootScreen.astro). -->
  <section class="scene scene-hero" aria-label="Apex">
    <div class="hero-scene" aria-hidden="true">
      <video
        data-hero-video
        class="hero-video"
        src="https://video.wixstatic.com/video/67964a_d30f1f2be4584a65924f05e849b1df3a/720p/mp4/file.mp4"
        poster="https://static.wixstatic.com/media/67964a_d30f1f2be4584a65924f05e849b1df3af002.jpg"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      ></video>
      <div class="hero-video-scrim"></div>
    </div>
    <div class="scene-watermark" aria-hidden="true">APEX</div>
    <div class="container-wide flex flex-col gap-12 relative z-10" data-hero-parallax>
      {/* Hidden for now, per request — restore by uncommenting.
      <p class="eyebrow" data-reveal>Supercar driving experiences</p> */}
      <h1 class="display-hero" data-reveal style="--d:100ms">
        Commit to<br />the corner<span class="accent-dot">.</span>
      </h1>
      <p class="text-xl md:text-2xl text-mute max-w-prose leading-relaxed" data-reveal style="--d:220ms">
        A supercar, a circuit, a time slot — book and drive the racing line yourself.
      </p>
      <div class="flex flex-wrap gap-4 mt-2" data-reveal style="--d:340ms">
        <a href="/services" class="btn-primary">Book a drive</a>
        <a href="#programmes" class="btn-secondary">The programmes</a>
      </div>
    </div>
    <div class="scroll-cue z-10" aria-hidden="true">Scroll</div>
  </section>

  <!-- Scene 2 — the fleet: pinned scroll sequence, one car per beat -->
  <section class="pin-stage border-t border-rule" data-pin-stage aria-label="The fleet" style="background-color: var(--color-paper-warm);">
    <div class="pin-viewport">
      <div class="container-wide flex flex-col gap-12">
        <div class="flex flex-col gap-5" data-reveal>
          <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_1fr] items-center gap-x-12 gap-y-6">
            <div class="hidden md:block"></div>
            <h2 class="display-lg text-center">Three cars. One discipline.</h2>
            <!-- Scroll progress as a racing curve. Short lead-in before circle
                 1 and short run-out after circle 3 (circles at 8%/50%/92% of
                 the arc, fractions carried on data-pin-dot); the scroll driver
                 maps section progress piecewise through those stops so the
                 fill crosses each circle exactly as its car takes the stage. -->
            <div class="pin-progress" aria-hidden="true">
              <svg class="pin-curve" viewBox="0 0 400 40" preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path class="pin-curve-base" d="M2 34 Q120 38 210 24 Q320 8 398 6" />
                <path class="pin-curve-fill" data-pin-bar pathLength="100" d="M2 34 Q120 38 210 24 Q320 8 398 6" />
              </svg>
              <span class="pin-dot" data-pin-dot="0.08" style="left:8.5%; top:35px"><span class="pin-dot-num">1</span></span>
              <span class="pin-dot" data-pin-dot="0.5" style="left:50%; top:26px"><span class="pin-dot-num">2</span></span>
              <span class="pin-dot" data-pin-dot="0.92" style="left:91.5%; top:7px"><span class="pin-dot-num">3</span></span>
            </div>
          </div>
        </div>
        <div class="pin-cars">
          {fleet.map((car, i) => (
            <article class={`pin-car${i === 0 ? " is-active" : ""}`} data-car-index={i}>
              <div class="pin-car-copy">
                <div class="pin-car-head">
                  <h3 class="pin-designation">{car.designation}</h3>
                  <p class="plate-role">{car.role}</p>
                </div>
                <div class="pin-car-foot">
                  <div class="plate-specs">
                    {car.specs.map((s) => (
                      <div>
                        <span class="plate-value">{s.value}<span class="plate-unit">{s.unit}</span></span>
                        <span class="plate-label">{s.label}</span>
                      </div>
                    ))}
                  </div>
                  <a href="/services" class="btn-primary">Book a drive</a>
                </div>
              </div>
              <div class="pin-car-media">
                <img src={car.image} alt={car.alt} loading={i === 0 ? "eager" : "lazy"} decoding="async" />
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- home:bookings -->
  <!-- Scene 3 — the programmes (live from Wix Bookings) -->
  <section id="programmes" class="scene" aria-label="The programmes">
    <div class="container-wide flex flex-col gap-14">
      <div class="flex flex-col gap-5" data-reveal>
        <p class="eyebrow">The programmes</p>
        <h2 class="display-xl">Pick your window.</h2>
      </div>
      {
        programmes.length > 0 ? (
          <div data-reveal style="--d:140ms">
            {programmes.map((s, i) => (
              <a href={`/services/${getSlug(s)}`} class="index-row">
                <span class="index-row-num">{String(i + 1).padStart(2, "0")}</span>
                <span class="index-row-name">{s.name}</span>
                <span class="index-row-meta">
                  <span>{getDuration(s)} min</span>
                  {formatPrice(s) && <span class="price">{formatPrice(s)}</span>}
                  <span class="index-row-arrow" aria-hidden="true">→</span>
                </span>
              </a>
            ))}
          </div>
        ) : (
          <div class="flex flex-col gap-6 items-start" data-reveal style="--d:140ms">
            <p class="text-mute leading-relaxed max-w-prose">
              The grid opens soon — sessions are being scheduled.
            </p>
            <a href="/services" class="btn-secondary">See all sessions</a>
          </div>
        )
      }
    </div>
  </section>

  <!-- Scene 4 — philosophy -->
  <section class="scene border-t border-rule" aria-label="Philosophy" style="background-color: var(--color-paper-warm);">
    <div class="container-wide flex flex-col gap-10 items-start">
      <p class="eyebrow" data-reveal>Why Apex</p>
      <p class="statement max-w-4xl" data-reveal style="--d:140ms">
        Speed is not the point.<br />
        Control at the <span class="text-accent font-semibold">edge</span> of it is.<br />
        <br />
        Every session pairs you with an instructor who lives on that edge — and teaches you to hold it.
      </p>
      <a href="/about" class="btn-secondary" data-reveal style="--d:280ms">The story behind Apex</a>
    </div>
  </section>

  <!-- Scene 5 — final call -->
  <section class="scene" aria-label="Book">
    <div class="container-wide flex flex-col gap-10 items-center text-center">
      <h2 class="display-hero" data-reveal>The grid<br />is open<span class="accent-dot">.</span></h2>
      <a href="/services" class="btn-primary" data-reveal style="--d:200ms">Book a drive</a>
    </div>
  </section>
</Layout>

<script>
  // Hero-video readiness — the boot curtain (BootScreen.astro) holds until
  // this fires (or its own 8s failsafe). Also parks the film under
  // prefers-reduced-motion: the poster frame stays, nothing moves.
  function initHeroVideo() {
    const video = document.querySelector<HTMLVideoElement>("[data-hero-video]:not([data-init])");
    if (!video) return;
    video.dataset.init = "1";
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      video.removeAttribute("autoplay");
      video.pause();
    }
    // With the loader up, hold the film on frame zero and start it only when
    // the curtain finishes (apex:boot-done) — the lap begins at reveal, not
    // behind the veil. Failsafe mirrors the head watchdog in case the boot
    // module died and only the watchdog cleared the curtain.
    if (document.documentElement.classList.contains("booting")) {
      video.pause();
      try {
        video.currentTime = 0;
      } catch {}
      const start = () => video.play().catch(() => {});
      document.addEventListener("apex:boot-done", start, { once: true });
      setTimeout(() => {
        if (video.paused && !document.documentElement.classList.contains("booting")) start();
      }, 14000);
    }
    const announce = () => document.dispatchEvent(new CustomEvent("apex:hero-video-ready"));
    if (video.readyState >= 3) announce();
    else {
      video.addEventListener("canplaythrough", announce, { once: true });
      video.addEventListener("error", announce, { once: true });
    }
  }
  initHeroVideo();
  document.addEventListener("astro:page-load", initHeroVideo);
</script>
